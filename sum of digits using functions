#include <stdio.h>
void num(int n);

int main() {
    int a;
    printf("Enter a number: ");
    scanf("%d", &a)
    num(a);
    return 0;
}
void num(int n) {
    int sum = 0;
    int digit;
    while (n != 0) {
        digit = n % 10;   
        sum = sum + digit; 
        n = n / 10;       
    }
    printf("sum = %d", sum);
}
