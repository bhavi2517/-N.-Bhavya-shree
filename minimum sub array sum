#include <stdio.h>
int main() {
    int arr[] = {3, -4, 2, -3, -1, 7, -5};
    int n = 7;

    int min_sum = arr[0], curr_sum = arr[0];

    for(int i = 1; i < n; i++) {
        if(curr_sum + arr[i] < arr[i])
            curr_sum = curr_sum + arr[i];
        else
            curr_sum = arr[i];

        if(curr_sum < min_sum)
            min_sum = curr_sum;
    }

    printf("Minimum Subarray Sum = %d", min_sum);
    return 0;
}
