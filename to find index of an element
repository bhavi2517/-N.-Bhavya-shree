#include <stdio.h>
int main() {
    int arr[5] = {10, 20, 30, 40, 50}, key = 30, index = -1;
    for(int i = 0; i < 5; i++) {
        if(arr[i] == key) {
            index = i;
            break;
        }
    }
    if(index != -1)
        printf("Element found at index %d", index);
    else
        printf("Element not found");
    return 0;
}
