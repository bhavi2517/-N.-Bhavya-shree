#include <stdio.h>

void main() {
    int i, j, n, num = 1;
    // Input how many rows you want (e.g., 4)
    scanf("%d", &n); 

    for (i = 1; i <= n; i++) {
        // Change: j <= i (not j <= 1)
        for (j = 1; j <= i; j++) { 
            printf("%d", num);
            num++;
        }
        printf("\n");
    }
}
