#include <stdio.h>
int main() {
    int arr[] = {1, 2, 3};
    int n = 3;

    for(int i = 0; i < n; i++) {
        for(int j = i; j < n; j++) {
            int sum = 0;
            for(int k = i; k <= j; k++) {
                sum += arr[k];
            }
            printf("Sum = %d\n", sum);
        }
    }
    return 0;
}
