#include <stdio.h>

int main()
{
    int i, n, a = 0, b = 1, next;

    printf("Enter the value of N: ");
    scanf("%d", &n);

    printf("Even Fibonacci numbers:\n");

    for(i = 1; i <= n; i++)
    {
        if(a % 2 == 0)
        {
            printf("%d\n", a);
        }

        next = a + b;
        a = b;
        b = next;
    }

    return 0;
}
