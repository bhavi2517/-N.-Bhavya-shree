#include <stdio.h>
void num(int n);

int main() {
    int a;
    printf("Enter a number: ");
    scanf("%d", &a);
    
    num(a); 
    return 0;
}

void num(int n) {
    int sum = 0; 
    int i;       
    
    for(i = 1; i <= n; i++) {
        sum = sum * i;
    }
    
    printf("sum = %d\n", sum);
}
