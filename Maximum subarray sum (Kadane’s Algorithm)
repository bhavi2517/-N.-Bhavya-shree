#include <stdio.h>
int main() {
    int arr[] = {-2, 1, -3, 4, -1, 2, 1, -5, 4};
    int n = 9;

    int max_sum = arr[0], curr_sum = arr[0];

    for(int i = 1; i < n; i++) {
        if(curr_sum + arr[i] > arr[i])
            curr_sum = curr_sum + arr[i];
        else
            curr_sum = arr[i];

        if(curr_sum > max_sum)
            max_sum = curr_sum;
    }

    printf("Maximum Subarray Sum = %d", max_sum);
    return 0;
}
