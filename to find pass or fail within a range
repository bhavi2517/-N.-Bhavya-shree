#include <stdio.h>

int main()
{
    int m1, m2, m3;
    float avg;

    printf("Enter the 3 subject marks: ");
    scanf("%d %d %d", &m1, &m2, &m3);

    avg = (m1 + m2 + m3) / 3.0;

    if(avg > 40 && m1 > 35 && m2 > 35 && m3 > 35)
        printf("student passed");
    else
        printf("student failed");

    return 0;
}
