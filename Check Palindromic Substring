#include <stdio.h>
#include <string.h>

int isPalindrome(char *s, int start, int end) {
    while (start < end) {
        if (s[start++] != s[end--]) return 0;
    }
    return 1;
}

int main() {
    char str[] = "madam";
    int len = strlen(str);

    for (int i = 0; i < len; i++) {
        for (int j = i; j < len; j++) {
            if (isPalindrome(str, i, j)) {
                for (int k = i; k <= j; k++)
                    printf("%c", str[k]);
                printf("\n");
            }
        }
    }
    return 0;
}
