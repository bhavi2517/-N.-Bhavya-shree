#include <stdio.h>
int main() {
    int arr[5] = {1, 2, 3, 2, 1}, flag = 1;
    for(int i = 0; i < 5/2; i++) {
        if(arr[i] != arr[5 - i - 1]) {
            flag = 0;
            break;
        }
    }
    if(flag)
        printf("Palindrome array");
    else
        printf("Not a palindrome");
    return 0;
}
