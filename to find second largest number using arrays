#include <stdio.h>
int main() {
    int arr[5]={5,2,8,1,9}, max=0, second=0;
    for(int i=0;i<5;i++){
        if(arr[i]>max){
            second=max;
            max=arr[i];
        } else if(arr[i]>second && arr[i]!=max){
            second=arr[i];
        }
    }
    printf("Second Largest=%d", second);
    return 0;
}
